# Public Supabase keys (safe in the browser, restricted by RLS)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Service role key — required by API routes that read/write across users
# (sidebar-counts, Kapso webhook, scraper). Never ship to the browser.
# Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# URL of the NestJS backend
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Kapso (WhatsApp Business)
KAPSO_API_KEY="<kapso-api-key>"
KAPSO_API_BASE_URL="https://api.kapso.ai"
KAPSO_PHONE_NUMBER_ID="<phone-number-id>"
KAPSO_WABA_ID="<whatsapp-business-account-id>"
KAPSO_TEMPLATE_NAME="<template-name>"
KAPSO_TEMPLATE_LANGUAGE="es_AR"
KAPSO_DEFAULT_COUNTRY_ISO="AR"
META_GRAPH_VERSION="v24.0"
# Generated when you register the webhook (see apps/web/scripts/register-kapso-webhook.md)
KAPSO_WEBHOOK_SECRET=""
# Personal WhatsApp number that receives owner notifications when Casita IA proposes a visit
KAPSO_OWNER_PHONE="+549..."
