    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./artists": {
      "types": "./src/artists.ts",
      "default": "./src/artists.ts"
    },
    "./works": {
      "types": "./src/works.ts",
      "default": "./src/works.ts"
    },
    "./recordings": {
      "types": "./src/recordings.ts",
      "default": "./src/recordings.ts"
    },
    "./evidence": {
      "types": "./src/evidence.ts",
      "default": "./src/evidence.ts"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "default": "./src/contracts.ts"
    },
    "./claims": {
      "types": "./src/claims.ts",
      "default": "./src/claims.ts"
