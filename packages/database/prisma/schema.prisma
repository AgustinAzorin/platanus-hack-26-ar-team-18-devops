generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Mirrors the Supabase Auth user via id (uuid). Profile data lives here.
/// id MUST equal auth.users.id from Supabase so RLS policies can reference it
/// (mock users inserted without auth use a synthetic uuid and won't pass RLS).
model User {
  id                  String   @id @db.Uuid
  email               String   @unique
  name                String?
  avatarUrl           String?  @map("avatar_url")
  phoneE164           String?  @map("phone_e164")
  /// Client-profile fields. Captured once by the search agent and reused.
  hasPet              Boolean? @map("has_pet")
  petDetails          String?  @map("pet_details")
  hasRealEstate       Boolean? @map("has_real_estate")
  realEstateLocation  String?  @map("real_estate_location")
  hasGuarantor        Boolean? @map("has_guarantor")
  guarantorDetails    String?  @map("guarantor_details")
  /// 'has' | 'can_contract' | 'no'
  caucionStatus       String?  @map("caucion_status")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Analysis {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  scrapedData Json     @map("scraped_data")
  report      Json
  score       Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([url, createdAt(sort: Desc)], map: "analyses_url_created_at_idx")
  @@index([createdAt(sort: Desc)], map: "analyses_created_at_idx")
  @@map("analyses")
}
